---
import Layout from "../layouts/Layout.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<Layout title="Página não encontrada" description="A página que você procura não existe ou foi movida.">
  <section class="py-24 md:py-36">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-8xl font-heading font-bold text-neutral-200 mb-4">404</p>
      <h1 class="text-2xl md:text-3xl font-heading font-bold text-neutral-900 mb-4">Página não encontrada</h1>
      <p class="text-neutral-500 mb-8 max-w-md mx-auto">A página que você procura não existe ou foi movida.</p>
      <a href={base} class="inline-flex items-center px-5 py-2.5 rounded-lg bg-neutral-900 text-white text-sm font-medium hover:bg-neutral-800 transition-colors">
        Voltar para o início
      </a>
    </div>
  </section>
</Layout>
